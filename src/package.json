{
  "name": "obsidian-forest",
  "version": "1.0.0",
  "description": "Forest-style syntactic trees for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
